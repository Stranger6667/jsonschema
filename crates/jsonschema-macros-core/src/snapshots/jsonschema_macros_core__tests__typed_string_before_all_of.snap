---
source: crates/jsonschema-macros-core/src/tests.rs
description: "{\"allOf\":[{\"minLength\":1},{\"maxLength\":5}],\"type\":\"string\"}"
expression: is_valid_body(schema)
---
(instance.is_string())
            && ((match instance {
                __Value::String(s) => !s.is_empty(),
                _ => true,
            })
                && (match instance {
                    __Value::String(s) => (s.chars().count() as u64) <= 5,
                    _ => true,
                }))
