---
source: crates/jsonschema-macros-core/src/tests.rs
description: "{\"$schema\":\"http://json-schema.org/draft-07/schema#\",\"contentEncoding\":\"base64\",\"contentMediaType\":\"application/json\",\"type\":\"string\"}"
expression: is_valid_body(schema)
---
match instance {
            __Value::String(s) => {
                match jsonschema::__private::content::from_base64(s) {
                    Ok(Some(__decoded)) => {
                        jsonschema::__private::content::is_json(&__decoded)
                    }
                    _ => false,
                }
            }
            _ => false,
        }
