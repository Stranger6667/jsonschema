---
source: crates/jsonschema-macros-core/src/tests.rs
description: "{\"$schema\":\"https://json-schema.org/draft/2020-12/schema\",\"items\":{\"type\":\"string\"},\"prefixItems\":[{\"type\":\"integer\"}],\"type\":\"array\"}"
expression: is_valid_body(schema)
---
match instance {
            __Value::Array(arr) => {
                (arr.iter().skip(1usize).all(|instance| instance.is_string()))
                    && (arr
                        .get(0usize)
                        .map_or(
                            true,
                            |instance| match instance {
                                __Value::Number(n) => __types::is_integer(n),
                                _ => false,
                            },
                        ))
            }
            _ => false,
        }
