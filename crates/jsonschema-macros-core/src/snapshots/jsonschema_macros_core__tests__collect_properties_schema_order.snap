---
source: crates/jsonschema-macros-core/src/tests.rs
description: "{\"properties\":{\"a\":{\"type\":\"integer\"},\"b\":{\"type\":\"integer\"}}}"
expression: collect_body(schema)
---
match instance {
            __Value::Object(obj) => {
                if let Some(value) = obj.get("a") {
                    let instance = value;
                    if !(match instance {
                        __Value::Number(n) => __types::is_integer(n),
                        _ => false,
                    }) {
                        let __path = &__path.push("a");
                        if !(match instance {
                            __Value::Number(n) => __types::is_integer(n),
                            _ => false,
                        }) {
                            __errors
                                .push(
                                    __err::single_type(
                                        "/properties/a/type",
                                        __path.into(),
                                        instance,
                                        __JT::Integer,
                                    ),
                                );
                        }
                    }
                }
                if let Some(value) = obj.get("b") {
                    let instance = value;
                    if !(match instance {
                        __Value::Number(n) => __types::is_integer(n),
                        _ => false,
                    }) {
                        let __path = &__path.push("b");
                        if !(match instance {
                            __Value::Number(n) => __types::is_integer(n),
                            _ => false,
                        }) {
                            __errors
                                .push(
                                    __err::single_type(
                                        "/properties/b/type",
                                        __path.into(),
                                        instance,
                                        __JT::Integer,
                                    ),
                                );
                        }
                    }
                }
            }
            _ => {}
        }
