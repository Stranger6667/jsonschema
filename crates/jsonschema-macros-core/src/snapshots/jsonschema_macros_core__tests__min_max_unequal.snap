---
source: crates/jsonschema-macros-core/src/tests.rs
description: "{\"maximum\":10,\"minimum\":1,\"type\":\"number\"}"
expression: is_valid_body(schema)
---
match instance {
            __Value::Number(n) => {
                (jsonschema::__private::numeric::ge(n, 1u64))
                    && (jsonschema::__private::numeric::le(n, 10u64))
            }
            _ => false,
        }
