---
source: crates/jsonschema-macros-core/src/tests.rs
description: "{\"$schema\":\"http://json-schema.org/draft-07/schema#\",\"additionalItems\":{\"type\":\"integer\"},\"contains\":{\"type\":\"string\"},\"items\":[{\"type\":\"integer\"}],\"type\":\"array\"}"
expression: is_valid_body(schema)
---
match instance {
            __Value::Array(arr) => {
                ((arr
                    .get(0usize)
                    .map_or(
                        true,
                        |instance| match instance {
                            __Value::Number(n) => __types::is_integer(n),
                            _ => false,
                        },
                    ))
                    && (arr
                        .iter()
                        .skip(1usize)
                        .all(|instance| match instance {
                            __Value::Number(n) => __types::is_integer(n),
                            _ => false,
                        }))) && (arr.iter().any(|instance| instance.is_string()))
            }
            _ => false,
        }
