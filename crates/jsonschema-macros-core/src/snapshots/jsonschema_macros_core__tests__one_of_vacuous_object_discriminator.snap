---
source: crates/jsonschema-macros-core/src/tests.rs
description: "{\"oneOf\":[{\"additionalProperties\":false,\"properties\":{\"k\":{\"const\":\"a\"},\"x\":{\"type\":\"integer\"}},\"required\":[\"k\"]},{\"additionalProperties\":false,\"properties\":{\"k\":{\"const\":\"b\"}},\"required\":[\"k\"]}]}"
expression: is_valid_body(schema)
---
{
            let __one_of_discriminator = match instance {
                serde_json::Value::Object(obj) => {
                    obj.get("k").and_then(serde_json::Value::as_str)
                }
                _ => None,
            };
            let mut matched = (matches!(__one_of_discriminator, Some("a"))
                && {
                    match instance {
                        serde_json::Value::Object(obj) => {
                            obj.iter()
                                .all(|(key, instance)| {
                                    let key_str = key.as_str();
                                    match key_str {
                                        "k" => true,
                                        "x" => {
                                            match instance {
                                                serde_json::Value::Number(n) => {
                                                    jsonschema::__private::types::is_integer(n)
                                                }
                                                _ => false,
                                            }
                                        }
                                        _ => false,
                                    }
                                })
                        }
                        _ => true,
                    }
                });
            (if (matches!(__one_of_discriminator, Some("b"))
                && {
                    match instance {
                        serde_json::Value::Object(obj) => {
                            obj.keys().all(|key| { matches!(key.as_str(), "k") })
                        }
                        _ => true,
                    }
                })
            {
                if matched {
                    false
                } else {
                    matched = true;
                    true
                }
            } else {
                true
            }) && matched
        }
