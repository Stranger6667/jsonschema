---
source: crates/jsonschema-macros-core/src/tests.rs
description: "{\"maxLength\":5,\"minLength\":2,\"type\":\"string\"}"
expression: is_valid_body(schema)
---
match instance {
            __Value::String(s) => {
                let len = s.chars().count();
                (len as u64) >= 2 && (len as u64) <= 5
            }
            _ => false,
        }
