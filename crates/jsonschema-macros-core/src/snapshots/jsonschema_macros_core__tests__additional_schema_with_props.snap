---
source: crates/jsonschema-macros-core/src/tests.rs
description: "{\"additionalProperties\":{\"type\":\"integer\"},\"properties\":{\"a\":{}},\"type\":\"object\"}"
expression: is_valid_body(schema)
---
match instance {
            __Value::Object(obj) => {
                obj.iter()
                    .all(|(key, instance)| {
                        let key_str = key.as_str();
                        match key_str {
                            "a" => true,
                            _ => {
                                match instance {
                                    __Value::Number(n) => __types::is_integer(n),
                                    _ => false,
                                }
                            }
                        }
                    })
            }
            _ => false,
        }
