                }
            }
            _ => {
                __errors
                    .push(
                        jsonschema::__private::error::single_type(
                            "/type",
                            __path.into(),
                            instance,
                            jsonschema::JsonType::Object,
                        ),
                    );
            }
        }
        __JSONSCHEMA_DYNAMIC_COLLECT_STACK
            .with(|stack| {
                let mut stack = stack.borrow_mut();
                for _ in 0..1usize {
                    stack.pop();
                }
            });
        __JSONSCHEMA_DYNAMIC_ITEM_EVAL_STACK
            .with(|stack| {
                let mut stack = stack.borrow_mut();
                for _ in 0..1usize {
                    stack.pop();
                }
            });
        __JSONSCHEMA_DYNAMIC_KEY_EVAL_STACK
            .with(|stack| {
                let mut stack = stack.borrow_mut();
                for _ in 0..1usize {
                    stack.pop();
                }
            });
        __JSONSCHEMA_DYNAMIC_STACK
            .with(|stack| {
                let mut stack = stack.borrow_mut();
                for _ in 0..1usize {
                    stack.pop();
                }
            });
    }
}
impl Validator {
    pub fn is_valid(instance: &serde_json::Value) -> bool {
        __validator_impl::is_valid(instance)
    }
    pub fn validate<'__i>(
        instance: &'__i serde_json::Value,
    ) -> ::std::result::Result<(), jsonschema::ValidationError<'__i>> {
        match __validator_impl::validate(
            instance,
            &jsonschema::paths::LazyLocation::new(),
        ) {
            Some(e) => Err(e),
            None => Ok(()),
        }
    }
    pub fn iter_errors<'__i>(
        instance: &'__i serde_json::Value,
    ) -> jsonschema::ErrorIterator<'__i> {
        let mut errors = Vec::new();
        __validator_impl::collect_errors(
            instance,
            &jsonschema::paths::LazyLocation::new(),
            &mut errors,
        );
        jsonschema::__private::error::iterator_from(errors)
    }
}
