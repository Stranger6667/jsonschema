---
source: crates/jsonschema-macros-core/src/tests.rs
description: "{\"allOf\":[{\"type\":\"string\"},{\"minLength\":1}]}"
expression: is_valid_body(schema)
---
(instance.is_string())
            && (match instance {
                serde_json::Value::String(s) => !s.is_empty(),
                _ => true,
            })
