---
source: crates/jsonschema-macros-core/src/tests.rs
description: "{\"oneOf\":[{\"properties\":{\"kind\":{\"const\":\"circle\"},\"radius\":{\"type\":\"number\"}},\"required\":[\"kind\"],\"type\":\"object\"},{\"properties\":{\"kind\":{\"const\":\"square\"},\"side\":{\"type\":\"number\"}},\"required\":[\"kind\"],\"type\":\"object\"}]}"
expression: is_valid_body(schema)
---
{
            let __one_of_discriminator = match instance {
                __Value::Object(obj) => obj.get("kind").and_then(__Value::as_str),
                _ => None,
            };
            let mut matched = (matches!(__one_of_discriminator, Some("circle"))
                && { is_branch_valid_0(instance) });
            (if (matches!(__one_of_discriminator, Some("square"))
                && { is_branch_valid_1(instance) })
            {
                if matched {
                    false
                } else {
                    matched = true;
                    true
                }
            } else {
                true
            }) && matched
        }
