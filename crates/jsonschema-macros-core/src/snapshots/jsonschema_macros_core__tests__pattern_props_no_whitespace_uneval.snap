---
source: crates/jsonschema-macros-core/src/tests.rs
description: "{\"patternProperties\":{\"^\\\\S*$\":{}},\"type\":\"object\",\"unevaluatedProperties\":false}"
expression: is_valid_body(schema)
---
match instance {
            __Value::Object(obj) => {
                ({
                    let __object_pass = obj.iter().all(|(key, instance)| { true });
                    __object_pass
                })
                    && (obj
                        .iter()
                        .all(|(__key, __value)| {
                            let key_str = __key.as_str();
                            if !key_str
                                .chars()
                                .any(jsonschema::__private::regex::is_ecma_whitespace)
                            {
                                true
                            } else {
                                false
                            }
                        }))
            }
            _ => false,
        }
