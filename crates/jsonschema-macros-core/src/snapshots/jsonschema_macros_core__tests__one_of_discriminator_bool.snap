{
            let __one_of_discriminator = match instance {
                serde_json::Value::Object(obj) => {
                    obj.get("active").and_then(serde_json::Value::as_bool)
                }
                _ => None,
            };
            let mut matched = (matches!(__one_of_discriminator, Some(true))
