      "allOf": [
        {
          "const": 3.14e-3
        },
        {
          "enum": [
            0.00314
          ]
        }
      ]
    },
    "tests": [
      {
        "data": 0.00314,
        "valid": true
      }
    ],
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "const": 0.00314
    }
  },
  {
