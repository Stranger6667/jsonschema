  {
    "description": "number intersect multitype with integer is not empty - admits integer witness",
    "schema": {
      "allOf": [
        {
          "type": "number"
        },
        {
          "type": [
            "null",
            "integer"
          ]
        }
      ]
    },
    "tests": [
