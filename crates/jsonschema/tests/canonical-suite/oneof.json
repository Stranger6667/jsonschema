[
  {
    "description": "single_branch_oneof_collapses_to_the_branch",
    "schema": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "string",
      "minLength": 1
    },
    "tests": [
      {
        "data": "a",
        "valid": true
      },
      {
        "data": "",
        "valid": false
      },
      {
        "data": 5,
        "valid": false
      }
    ]
  },
  {
    "description": "single_branch_oneof_conjoins_with_allof_and_anyof",
    "schema": {
      "allOf": [
        {
          "multipleOf": 2
        }
      ],
      "anyOf": [
        {
          "multipleOf": 3
        }
      ],
      "oneOf": [
        {
          "multipleOf": 5
        }
      ]
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "anyOf": [
        {
          "type": [
            "null",
            "boolean",
            "string",
            "array",
            "object"
          ]
        },
        {
          "type": "integer",
          "multipleOf": 30
        }
      ]
    },
    "tests": [
      {
        "data": 30,
        "valid": true
      },
      {
        "data": 10,
        "valid": false
      },
      {
        "data": "x",
        "valid": true
      }
    ]
  },
  {
    "description": "oneof_of_true_and_false_branches_is_true",
    "schema": {
      "oneOf": [
        true,
        false,
        false
      ]
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema"
    },
    "tests": [
      {
        "data": 1,
        "valid": true
      },
      {
        "data": "a",
        "valid": true
      },
      {
        "data": null,
        "valid": true
      }
    ]
  },
  {
    "description": "oneof_of_only_false_branches_is_unsatisfiable",
    "schema": {
      "oneOf": [
        false,
        false,
        false
      ]
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "not": {}
    },
    "satisfiable": false,
    "tests": [
      {
        "data": 1,
        "valid": false
      },
      {
        "data": null,
        "valid": false
      }
    ]
  },
  {
    "description": "disjoint_typed_branches_converge_with_the_equivalent_anyof",
    "schemas": [
      {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "integer"
          }
        ]
      },
      {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "integer"
          }
        ]
      }
    ],
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": [
        "integer",
        "string"
      ]
    },
    "tests": [
      {
        "data": "a",
        "valid": true
      },
      {
        "data": 1,
        "valid": true
      },
      {
        "data": 1.5,
        "valid": false
      },
      {
        "data": null,
        "valid": false
      }
    ]
  },
  {
    "description": "branches_disjoint_by_value_fold_into_one_enum",
    "schema": {
      "oneOf": [
        {
          "enum": [
            "a",
            "b"
          ]
        },
        {
          "enum": [
            1,
            2
          ]
        }
      ]
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "enum": [
        1,
        2,
        "a",
        "b"
      ]
    },
    "tests": [
      {
        "data": "a",
        "valid": true
      },
      {
        "data": 1,
        "valid": true
      },
      {
        "data": 3,
        "valid": false
      }
    ]
  },
  {
    "description": "branches_disjoint_by_integer_window_merge_when_adjacent",
    "schema": {
      "oneOf": [
        {
          "type": "integer",
          "maximum": 0
        },
        {
          "type": "integer",
          "minimum": 1
        }
      ]
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "integer"
    },
    "tests": [
      {
        "data": 0,
        "valid": true
      },
      {
        "data": 1,
        "valid": true
      },
      {
        "data": 1.5,
        "valid": false
      }
    ]
  },
  {
    "description": "overlapping_branches_take_the_exact_encoding",
    "schema": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "minLength": 1
        }
      ]
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "anyOf": [
        {
          "type": [
            "null",
            "boolean",
            "number",
            "array",
            "object"
          ]
        },
        {
          "const": ""
        }
      ]
    },
    "tests": [
      {
        "data": "",
        "valid": true
      },
      {
        "data": "a",
        "valid": false
      },
      {
        "data": 5,
        "valid": true
      }
    ]
  },
  {
    "description": "a_branch_overlapping_only_by_vacuity_is_never_negated",
    "schema": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "contains": {
            "type": "number"
          }
        }
      ]
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "anyOf": [
        {
          "type": [
            "null",
            "boolean",
            "number",
            "object"
          ]
        },
        {
          "type": "array",
          "contains": {
            "type": "number"
          }
        }
      ]
    },
    "tests": [
      {
        "data": "a",
        "valid": false
      },
      {
        "data": [
          1
        ],
        "valid": true
      },
      {
        "data": [
          ""
        ],
        "valid": false
      }
    ]
  },
  {
    "description": "only_the_overlapping_pair_pays_its_complement",
    "schema": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": [
            "string",
            "null"
          ]
        }
      ]
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": [
        "null",
        "integer"
      ]
    },
    "tests": [
      {
        "data": null,
        "valid": true
      },
      {
        "data": "a",
        "valid": false
      },
      {
        "data": 1,
        "valid": true
      }
    ]
  },
  {
    "description": "draft4_branches_disjoint_by_enum_value_fold_into_one_enum",
