        }
      ]
    },
    "expected": {
      "oneOf": [
        true,
        {
          "type": "string"
        }
      ]
    },
    "tests": [
      {
        "data": "a",
        "valid": false
      },
      {
        "data": 5,
        "valid": true
      }
    ]
  },
  {
    "description": "a_false_branch_beside_a_real_branch_is_dropped",
