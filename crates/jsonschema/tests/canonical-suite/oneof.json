            "a"
          ]
        },
        {
          "enum": [
            1
          ]
        }
      ]
    },
    "expected": {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "enum": [
        1,
        "a"
      ]
    },
    "tests": [
      {
        "data": "a",
        "valid": true
      },
      {
        "data": 1,
        "valid": true
      },
      1.0,
      {
        "data": 2,
        "valid": false
      }
    ]
  },
  {
    "description": "duplicate_branches_overlap_and_stay_raw",
