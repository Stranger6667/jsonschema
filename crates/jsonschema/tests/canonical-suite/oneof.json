        }
      ]
    },
    "expected": {
      "oneOf": [
        {
          "const": 1
        },
        {
          "const": 1
        }
      ]
    },
    "tests": [
      {
        "data": 1,
        "valid": false
      },
      {
        "data": 2,
        "valid": false
      }
    ]
  },
  {
    "description": "a_true_branch_overlaps_every_satisfiable_branch",
