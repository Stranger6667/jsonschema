          "oneOf": [
            {
              "type": "string"
            },
            {
              "minLength": 1
            }
          ]
        }
      }
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "a": {
          "anyOf": [
            {
              "type": [
                "null",
                "boolean",
                "number",
                "array",
                "object"
              ]
            },
            {
              "const": ""
            }
          ]
        }
      }
    },
    "tests": [
      {
        "data": {
          "a": ""
        },
        "valid": true
