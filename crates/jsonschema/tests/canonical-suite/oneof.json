  {
    "description": "overlapping windows keep exactly the non-shared rays",
    "schema": {
      "oneOf": [
        {
          "type": "number",
          "minimum": 0
        },
        {
          "type": "number",
          "maximum": 10
        }
      ]
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "anyOf": [
        {
          "type": "number",
          "exclusiveMaximum": 0
        },
        {
          "type": "number",
          "exclusiveMinimum": 10
        }
      ]
    },
    "tests": [
      {
        "data": 5,
        "valid": false
      },
      {
        "data": 11,
        "valid": true
      },
      {
        "data": -1,
        "valid": true
      },
      {
        "data": "x",
        "valid": false
      }
    ]
  },
