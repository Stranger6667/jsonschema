        {
          "enum": [
            1,
            2
          ]
        },
        {
          "enum": [
            2,
            3
          ]
        }
      ]
    },
    "tests": [
      {
        "data": 1,
        "valid": true
      },
      {
        "data": 2,
        "valid": false
      },
      {
        "data": 3,
        "valid": true
      },
      {
        "data": 4,
        "valid": false
      }
    ]
  },
  {
    "description": "an_overlapping_oneof_inside_properties_keeps_the_document_raw",
    "schema": {
      "type": "object",
      "properties": {
        "a": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "minLength": 1
            }
          ]
        }
      }
    },
    "expected": {
      "type": "object",
      "properties": {
        "a": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "minLength": 1
            }
          ]
        }
      }
    },
    "tests": [
      {
        "data": {
          "a": ""
        },
        "valid": true
      },
      {
        "data": {
          "a": "x"
        },
        "valid": false
      },
      {
        "data": {
