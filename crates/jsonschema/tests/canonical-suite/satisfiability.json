  {
    "description": "admits oracle coverage - anyof null bounded integer parity and satisfiability",
    "schema": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "enum": [
            1,
            2,
            3
          ]
        }
      ]
    },
    "tests": [
      {
        "data": null,
        "valid": true
      },
      {
        "data": 1,
        "valid": true
      },
      {
        "data": 2,
        "valid": true
      },
      {
        "data": 3,
        "valid": true
      },
      {
        "data": "x",
        "valid": false
      },
      {
        "data": 0,
        "valid": false
      }
    ],
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "enum": [
        null,
        1,
        2,
        3
      ]
    }
  },
  {
    "description": "admits oracle coverage - allOf const string not anyof format parity and satisfiability",
    "schema": {
      "allOf": [
        {
          "const": "x"
        },
        {
          "not": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "string",
                "format": "email"
              }
            ]
          }
        }
      ]
    },
    "tests": [
      {
        "data": "x"
      },
      {
        "data": 1
      },
      {
        "data": null
      },
      {
        "data": "a@b.com"
      }
    ]
  },
  {
    "description": "admits oracle coverage - allOf const true not anyof format parity and satisfiability",
    "schema": {
      "allOf": [
        {
          "const": true
        },
        {
          "not": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "string",
                "format": "email"
              }
            ]
          }
        }
      ]
    },
    "tests": [
      {
        "data": true
      },
      {
        "data": false
      },
      {
        "data": 1
      },
      {
        "data": "x"
      },
      {
        "data": null
      }
    ]
  },
  {
    "description": "draft4 integer membership excludes float - enum with float member drops it for integer type",
    "schema": {
      "allOf": [
        {
          "type": "integer"
        },
        {
          "enum": [
            1,
            2.5,
            3
          ]
        }
      ]
    },
    "draft": "draft4",
    "tests": [
      {
        "data": 1,
        "valid": true
      },
      {
        "data": 1.0,
        "valid": false
      },
      {
        "data": 2,
        "valid": false
      },
      {
        "data": 2.5,
        "valid": false
      },
      {
        "data": 3,
        "valid": true
      }
    ],
    "expected": {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "enum": [
        1,
        3
      ],
      "type": "integer"
    }
  },
  {
    "description": "draft4 integer singleton bounds preserve float rejection - minimum equals maximum keeps integer-only",
    "schema": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1
    },
    "draft": "draft4",
    "tests": [
      {
        "data": 1,
        "valid": true
      },
      {
        "data": 1.0,
        "valid": false
      }
    ]
  },
  {
    "description": "draft4 integer enum filter preserves float rejection - enum with 1.0 keeps only integer 1",
    "schema": {
      "type": "integer",
      "enum": [
        1.0
      ]
    },
    "draft": "draft4",
    "tests": [
      {
        "data": 1,
