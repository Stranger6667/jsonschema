      "dependentSchemas": {
        "a": {
          "not": false
        }
      }
    }
  },
  {
    "description": "object_canonicalization_is_idempotent object-pinned allOf residual does not retain a redundant TypedGroup wrapper",
    "schema": {
      "allOf": [
        {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "patternProperties": {
            "^[a-zA-Z][a-zA-Z0-9-]*[a-zA-Z0-9]?$": {
              "type": "string"
            }
          }
        },
        {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "type": "string"
          }
        }
      ]
    }
  },
  {
    "description": "format_only_leaf_after_extended_not_pattern_drop_is_idempotent",
    "schema": {
      "type": "string",
