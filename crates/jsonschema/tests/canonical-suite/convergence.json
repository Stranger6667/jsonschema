  {
    "description": "a property entry widens by the sibling entry that covers the difference",
    "schemas": [
      {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "a": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "minProperties": 2,
            "properties": {
              "a": {
                "type": "null"
              }
            }
          }
        ]
      },
      {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "a": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "minProperties": 2,
            "properties": {
              "a": {
                "type": [
                  "null",
                  "string"
                ]
              }
            }
          }
        ]
      }
    ],
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "a": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "minProperties": 2,
          "properties": {
            "a": {
              "type": [
                "null",
                "string"
              ]
            }
          }
        }
      ]
    },
    "tests": [
      {
        "data": {},
        "valid": true
      },
      {
        "data": {
          "a": null,
          "b": 1
        },
        "valid": true
      },
      {
        "data": {
          "a": "x",
          "b": 1
        },
        "valid": true
      },
      {
        "data": {
          "a": 1,
          "b": 2
        },
        "valid": false
      },
      {
        "data": {
          "a": null
        },
        "valid": false
      }
    ]
  },
