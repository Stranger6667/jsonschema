  {
    "description": "union_min empty string window and the empty const denote one value set",
    "expected": {"$schema": "https://json-schema.org/draft/2020-12/schema", "type": "string"},
    "schemas": [
      {"anyOf": [{"type": "string", "minLength": 1}, {"type": "string", "maxLength": 0}]},
      {"anyOf": [{"type": "string", "minLength": 1}, {"const": ""}]},
      {"type": "string"}
    ]
  },
  {
    "description": "union_min a single integer beside a window is part of the window",
    "expected": {"$schema": "https://json-schema.org/draft/2020-12/schema", "type": "integer", "minimum": 5},
    "schemas": [
      {"anyOf": [{"type": "integer", "minimum": 6}, {"type": "integer", "minimum": 5, "maximum": 5}]},
      {"anyOf": [{"type": "integer", "minimum": 6}, {"const": 5}]},
      {"type": "integer", "minimum": 5}
    ]
  },
  {
    "description": "union_min a single integer filling the only gap covers every integer",
    "expected": {"$schema": "https://json-schema.org/draft/2020-12/schema", "type": "integer"},
    "schemas": [
      {"anyOf": [{"type": "integer", "maximum": 0}, {"type": "integer", "minimum": 2}, {"const": 1}]},
      {"type": "integer"}
    ]
  },
  {
    "description": "union_min draft 4 absorbs a guarded value set into a covering interval",
    "expected": {"$schema": "http://json-schema.org/draft-04/schema#", "type": "integer", "minimum": 2},
    "draft": "draft4",
    "schemas": [
      {"anyOf": [{"type": "integer", "minimum": 2}, {"type": "integer", "enum": [7]}]},
      {"type": "integer", "minimum": 2}
    ]
  },
  {
    "description": "union_min a string leaf absorbs a strictly narrower one",
    "expected": {"$schema": "https://json-schema.org/draft/2020-12/schema", "type": "string", "minLength": 2},
    "schemas": [
      {"anyOf": [{"type": "string", "minLength": 2}, {"type": "string", "minLength": 2, "pattern": "^a"}]},
      {"type": "string", "minLength": 2}
    ]
  },
  {
    "description": "union_min a vacuous pattern constrains nothing",
    "expected": {"$schema": "https://json-schema.org/draft/2020-12/schema", "type": "string"},
    "schemas": [
      {"anyOf": [{"type": "string", "pattern": ""}, {"type": "string", "minLength": 5}]},
      {"type": "string"}
    ]
  },
  {
    "description": "value-set intersection lands on the same node as the direct spelling",
    "schemas": [
      {
        "allOf": [
          {
            "enum": [1, 2]
          },
          {
            "enum": [2, 3]
          }
        ]
      },
      {
        "const": 2
      }
    ],
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "const": 2
    },
    "tests": [
      {
        "data": 2,
        "valid": true
      },
      {
        "data": 1,
        "valid": false
      },
      {
        "data": 3,
        "valid": false
      }
    ]
  },
  {
    "description": "draft 4 integer guard from intersection lands on the parse spelling",
    "draft": "draft4",
    "schemas": [
      {
        "allOf": [
          {
            "type": "integer"
          },
          {
            "enum": [1, 2, "a"]
          }
        ]
      },
      {
        "type": "integer",
        "enum": [1, 2]
      }
    ],
    "expected": {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "type": "integer",
      "enum": [1, 2]
    },
    "tests": [
      {
        "data": 1,
        "valid": true
      },
      {
        "data": 1.0,
        "valid": false
      },
      {
        "data": "a",
        "valid": false
      }
    ]
  },
  {
    "description": "finite-domain types dissolve into a loose value set",
    "schemas": [
      {
        "anyOf": [
          {
            "type": "boolean"
          },
          {
            "enum": [
              null,
              0
            ]
          }
        ]
      },
      {
        "anyOf": [
          {
            "type": [
              "null",
              "boolean"
            ]
          },
          {
            "const": 0
          }
        ]
      }
    ],
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "enum": [
        null,
        false,
        true,
        0
      ]
    },
    "tests": [
      {
        "data": null,
        "valid": true
      },
      {
        "data": true,
        "valid": true
      },
      {
        "data": 0,
        "valid": true
      },
      {
        "data": 1,
        "valid": false
      },
      {
        "data": "x",
        "valid": false
      }
    ]
  },
