        "data": "x",
        "valid": false
      },
      {
        "data": 1,
        "valid": true
      },
      {
        "data": 1.5,
        "valid": true
      },
      {
        "data": null,
        "valid": true
      },
      {
        "data": [],
        "valid": true
      }
    ]
  },
