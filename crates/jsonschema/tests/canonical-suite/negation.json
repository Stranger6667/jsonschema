[
  {
    "description": "not false matches everything",
    "schemas": [
      {
        "not": false
      },
      true
    ],
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema"
    },
    "tests": [
      {
        "data": 1,
        "valid": true
      },
      {
        "data": "x",
        "valid": true
      }
    ]
  },
  {
    "description": "not true matches nothing",
    "schemas": [
      {
        "not": true
      },
      {
        "not": {}
      },
      false
    ],
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "not": {}
    },
    "satisfiable": false,
    "tests": [
      {
        "data": 1,
        "valid": false
      }
    ]
  },
  {
