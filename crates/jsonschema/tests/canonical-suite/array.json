[
  {
    "description": "ir: array length window preserves validation",
    "schema": {"type": "array", "minItems": 1, "maxItems": 3},
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "array",
      "minItems": 1,
      "maxItems": 3
    },
    "tests": [
      {"data": [1], "valid": true},
      {"data": [1, 2, 3], "valid": true},
      {"data": [], "valid": false},
      {"data": [1, 2, 3, 4], "valid": false},
      {"data": {"a": 1}, "valid": false}
    ]
  },
  {
    "description": "ir: minItems zero converges to the bare type",
    "schemas": [
      {"type": "array", "minItems": 0},
      {"type": "array"}
    ],
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "array"
    }
  },
  {
    "description": "ir: bare minItems constrains only arrays",
    "schema": {"minItems": 1},
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "anyOf": [
        {"type": ["null", "boolean", "number", "string", "object"]},
        {"type": "array", "minItems": 1}
      ]
    },
    "tests": [
      {"data": [1], "valid": true},
      {"data": [], "valid": false},
      {"data": {}, "valid": true},
      {"data": "", "valid": true}
    ]
  },
  {
    "description": "ir: allOf of array length windows tightens to one leaf",
    "schema": {
      "allOf": [
        {"type": "array", "minItems": 2},
        {"type": "array", "minItems": 3, "maxItems": 5}
      ]
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "array",
      "minItems": 3,
      "maxItems": 5
    },
    "tests": [
      {"data": [1, 2, 3], "valid": true},
      {"data": [1, 2], "valid": false}
    ]
  },
  {
    "description": "ir: crossed array length bounds are unsatisfiable",
    "schema": {"type": "array", "minItems": 3, "maxItems": 2},
    "expected": {"$schema": "https://json-schema.org/draft/2020-12/schema", "not": {}},
    "satisfiable": false
  },
  {
    "description": "ir: an array window and an object window are unsatisfiable together",
    "schema": {
      "allOf": [
        {"type": "array", "minItems": 1},
        {"type": "object", "minProperties": 1}
      ]
    },
    "expected": {"$schema": "https://json-schema.org/draft/2020-12/schema", "not": {}},
    "satisfiable": false
  },
  {
    "description": "ir: an array window and a disjoint type are unsatisfiable",
    "schema": {
      "allOf": [
        {"type": "string"},
        {"type": "array", "minItems": 1}
      ]
    },
    "expected": {"$schema": "https://json-schema.org/draft/2020-12/schema", "not": {}},
    "satisfiable": false
  },
  {
    "description": "ir: adjacent array length windows merge into the bare type",
    "schema": {
      "anyOf": [
        {"type": "array", "maxItems": 2},
        {"type": "array", "minItems": 3}
      ]
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "array"
    },
    "tests": [
      {"data": [], "valid": true},
      {"data": [1, 2, 3, 4], "valid": true}
    ]
  },
  {
    "description": "ir: array length windows with a gap stay separate branches",
    "schema": {
      "anyOf": [
        {"type": "array", "maxItems": 1},
        {"type": "array", "minItems": 5}
      ]
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "anyOf": [
        {"type": "array", "maxItems": 1},
        {"type": "array", "minItems": 5}
      ]
    },
    "tests": [
      {"data": [1], "valid": true},
      {"data": [1, 2], "valid": false}
    ]
  },
  {
    "description": "ir: an array window subsumed by a wider one drops",
    "schema": {
      "anyOf": [
        {"type": "array", "minItems": 2, "maxItems": 4},
        {"type": "array", "minItems": 1, "maxItems": 6}
      ]
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "array",
      "minItems": 1,
      "maxItems": 6
    },
    "tests": [
      {"data": [1], "valid": true},
      {"data": [], "valid": false}
    ]
  },
  {
    "description": "ir: a constant array outside the length window is unsatisfiable",
    "schema": {
      "allOf": [
        {"const": [1]},
        {"minItems": 2}
      ]
    },
    "expected": {"$schema": "https://json-schema.org/draft/2020-12/schema", "not": {}},
    "satisfiable": false
  },
  {
    "description": "ir: a constant array inside the length window survives",
    "schema": {
      "allOf": [
        {"const": [1]},
        {"minItems": 1, "maxItems": 2}
      ]
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "const": [1]
    },
    "tests": [
      {"data": [1], "valid": true},
      {"data": [2], "valid": false}
    ]
  },
  {
    "description": "ir: an array window absorbs a constant array it admits",
    "schema": {
      "anyOf": [
        {"type": "array", "minItems": 1},
        {"const": [1]}
      ]
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "array",
      "minItems": 1
    },
    "tests": [
      {"data": [1], "valid": true},
      {"data": [], "valid": false}
    ]
  },
  {
    "description": "ir: maxItems zero converges to the empty array",
    "schemas": [
      {"type": "array", "maxItems": 0},
      {"const": []}
    ],
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "const": []
    },
    "tests": [
      {"data": [], "valid": true},
      {"data": [1], "valid": false},
      {"data": {}, "valid": false}
    ]
  },
  {
    "description": "ir: maxItems zero converges to the empty array under draft 4",
    "schemas": [
      {"type": "array", "maxItems": 0},
      {"enum": [[]]}
    ],
    "draft": "draft4",
    "expected": {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "enum": [[]]
    },
    "tests": [
      {"data": [], "valid": true},
      {"data": [1], "valid": false}
    ]
  },
  {
    "description": "ir: the empty array joins an array window it touches",
    "schema": {
      "anyOf": [
        {"type": "array", "minItems": 1},
        {"const": []}
      ]
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "array"
    },
    "tests": [
      {"data": [], "valid": true},
      {"data": [1], "valid": true},
      {"data": {}, "valid": false}
    ]
  },
  {
    "description": "ir: the empty array stays beside an array window with a gap",
    "schemas": [
      {
        "anyOf": [
          {"type": "array", "minItems": 3},
          {"const": []}
        ]
      },
      {
        "anyOf": [
          {"type": "array", "minItems": 3},
          {"type": "array", "maxItems": 0}
        ]
      }
    ],
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "anyOf": [
        {"type": "array", "minItems": 3},
        {"const": []}
      ]
    },
    "tests": [
      {"data": [], "valid": true},
      {"data": [1], "valid": false},
      {"data": [1, 2, 3], "valid": true}
    ]
  },
  {
    "description": "ir: bare minItems zero constrains nothing",
    "schemas": [
      {"minItems": 0},
      {}
    ],
    "expected": {"$schema": "https://json-schema.org/draft/2020-12/schema"},
    "tests": [
      {"data": [], "valid": true},
      {"data": 5, "valid": true}
    ]
  },
  {
    "description": "ir: an array window and an object window in a union stay apart",
    "schema": {
      "anyOf": [
        {"type": "array", "minItems": 1},
        {"type": "object", "minProperties": 1}
      ]
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "anyOf": [
        {"type": "array", "minItems": 1},
        {"type": "object", "minProperties": 1}
      ]
    },
    "tests": [
      {"data": [1], "valid": true},
      {"data": {"a": 1}, "valid": true},
      {"data": [], "valid": false},
      {"data": {}, "valid": false}
    ]
  },
  {
    "description": "ir: a length facet and a property-count facet split the untyped domain",
    "schema": {"minItems": 1, "minProperties": 1},
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "anyOf": [
        {"type": ["null", "boolean", "number", "string"]},
        {"type": "array", "minItems": 1},
        {"type": "object", "minProperties": 1}
      ]
    },
    "tests": [
      {"data": [1], "valid": true},
      {"data": {"a": 1}, "valid": true},
      {"data": [], "valid": false},
      {"data": {}, "valid": false},
      {"data": 5, "valid": true}
    ]
  },
  {
    "description": "ir: a property-count facet constrains nothing on arrays",
    "schema": {
      "allOf": [
        {"type": "array"},
        {"minProperties": 1}
      ]
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "array"
    },
    "tests": [
      {"data": [], "valid": true},
      {"data": [1], "valid": true},
      {"data": {"a": 1}, "valid": false}
    ]
  },
  {
    "description": "ir: an unsatisfiable length window drops only the array type",
    "schema": {
      "allOf": [
        {"minItems": 2},
        {"maxItems": 1}
      ]
    },
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": ["null", "boolean", "number", "string", "object"]
    },
    "tests": [
      {"data": [], "valid": false},
      {"data": [1], "valid": false},
      {"data": 5, "valid": true},
      {"data": {}, "valid": true}
    ]
  },
  {
    "description": "ir: a length window filters only the array members of an enum",
    "schema": {"enum": [[], [1], [1, 2], {"a": 1}], "minItems": 1},
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "enum": [[1], [1, 2], {"a": 1}]
    },
    "tests": [
      {"data": [1], "valid": true},
      {"data": {"a": 1}, "valid": true},
      {"data": [], "valid": false},
      {"data": [3], "valid": false}
    ]
  },
  {
    "description": "ir: a type list carries one window per container type",
    "schema": {"type": ["array", "object"], "minItems": 1, "maxProperties": 2},
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "anyOf": [
        {"type": "array", "minItems": 1},
        {"type": "object", "maxProperties": 2}
      ]
    },
    "tests": [
      {"data": [1], "valid": true},
      {"data": [], "valid": false},
      {"data": {"a": 1, "b": 2}, "valid": true},
      {"data": {"a": 1, "b": 2, "c": 3}, "valid": false},
      {"data": "x", "valid": false}
    ]
  },
  {
    "description": "ir: a length window pinned above zero stays a window",
    "schema": {"type": "array", "minItems": 2, "maxItems": 2},
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "array",
      "minItems": 2,
      "maxItems": 2
    },
    "tests": [
      {"data": [1, 2], "valid": true},
      {"data": ["a", "b"], "valid": true},
      {"data": [1], "valid": false}
    ]
  },
  {
    "description": "ir: an integer-valued float length bound converges with its integer spelling",
    "schemas": [
      {"type": "array", "maxItems": 2.0},
      {"type": "array", "maxItems": 2}
    ],
    "expected": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "array",
      "maxItems": 2
    },
    "tests": [
      {"data": [1, 2], "valid": true},
      {"data": [1, 2, 3], "valid": false}
    ]
  },
  {
    "description": "ir: array length window under draft 4",
    "schema": {"type": "array", "minItems": 1, "maxItems": 2},
    "draft": "draft4",
    "expected": {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "type": "array",
      "minItems": 1,
      "maxItems": 2
    },
    "tests": [
      {"data": [1], "valid": true},
      {"data": [], "valid": false}
    ]
  }
]
