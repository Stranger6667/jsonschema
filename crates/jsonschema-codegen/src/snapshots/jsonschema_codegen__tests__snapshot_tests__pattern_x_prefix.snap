---
source: crates/jsonschema-codegen/src/tests.rs
description: "{\"patternProperties\":{\"^x-\":{\"type\":\"string\"}}}"
expression: is_valid_body(schema)
---
match instance {
            serde_json::Value::Object(obj) => {
                obj.iter()
                    .filter(|(key, _)| key.as_str().starts_with("x-"))
                    .all(|(_, instance)| { instance.is_string() })
            }
            _ => true,
        }
