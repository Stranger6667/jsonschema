struct Validator;
#[doc(hidden)]
#[allow(non_snake_case, dead_code, unused_variables, clippy::all)]
mod __validator_impl {
    use super::*;
    pub(super) fn is_valid(instance: &serde_json::Value) -> bool {
        (match instance {
            serde_json::Value::Number(n) => {
                n.is_i64() || n.is_u64() || n.as_f64().is_some_and(|f| f.fract() == 0.0)
            }
            _ => false,
        }
            && match instance {
                serde_json::Value::Number(_) => {
                    static NUMBER_VARIANTS: std::sync::LazyLock<
                        Vec<serde_json::Value>,
                    > = std::sync::LazyLock::new(|| {
                        serde_json::from_str::<Vec<serde_json::Value>>("[1.5]")
                            .expect("Failed to parse number variants")
                    });
                    NUMBER_VARIANTS
                        .iter()
                        .any(|v| jsonschema::ext::cmp::equal(v, instance))
                }
                _ => false,
            })
    }
}
impl Validator {
    pub fn is_valid(instance: &serde_json::Value) -> bool {
        __validator_impl::is_valid(instance)
    }
}
